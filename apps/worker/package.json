{
  "name": "@rivet/worker",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/main.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --passWithNoTests",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage --passWithNoTests",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --config jest.integration.config.cjs --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@rivet/database": "workspace:*",
    "@rivet/event-contracts": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "nestjs-pino": "4.6.1",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@rivet/config": "workspace:*",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/web-push": "3.6.4",
    "dotenv": "17.4.2",
    "eslint": "10.6.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  }
}
