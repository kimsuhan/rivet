{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["API_INTERNAL_ORIGIN", "PLAYWRIGHT_API_PROXY", "RELEASE_ID"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "generate": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "migrate:test": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build", "@rivet/database#migrate:test"]
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "openapi:generate": {
      "cache": false,
      "outputs": ["openapi/openapi.json"]
    }
  }
}
