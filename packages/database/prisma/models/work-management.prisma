enum IssuePriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  UNSORTED
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  PAUSED
  CANCELED
}

enum ProjectRole {
  BACKEND
  WEB_FRONTEND
  APP_FRONTEND
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum HandoffKind {
  INITIAL
  FOLLOW_UP
}

enum NotificationType {
  TEAM_WORK_ASSIGNED
  MENTIONED
  COMMENT_ADDED
  ISSUE_COMPLETED
  ISSUE_CANCELED
  API_HANDOFF_CREATED
  API_HANDOFF_FOLLOW_UP_CREATED
}

enum WebPushBrowser {
  CHROME
  EDGE
  FIREFOX
  SAFARI
  OTHER
}

enum WebPushSubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum WebPushDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model Project {
  id                    String        @id @default(uuid()) @db.Uuid
  workspaceId           String        @map("workspace_id") @db.Uuid
  name                  String        @db.VarChar(200)
  description           String?       @db.VarChar(5000)
  status                ProjectStatus @default(PLANNED)
  leadMembershipId      String?       @map("lead_membership_id") @db.Uuid
  startDate             DateTime?     @map("start_date") @db.Date
  targetDate            DateTime?     @map("target_date") @db.Date
  archivedAt            DateTime?     @map("archived_at") @db.Timestamptz(3)
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz(3)
  purgeAt               DateTime?     @map("purge_at") @db.Timestamptz(3)
  deletedByMembershipId String?       @map("deleted_by_membership_id") @db.Uuid
  version               Int           @default(1)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  leadMembership      WorkspaceMembership? @relation("ProjectLeadMembership", fields: [workspaceId, leadMembershipId], references: [workspaceId, id], onDelete: Restrict)
  deletedByMembership WorkspaceMembership? @relation("ProjectDeletedByMembership", fields: [workspaceId, deletedByMembershipId], references: [workspaceId, id], onDelete: Restrict)
  roleTeams           ProjectRoleTeam[]
  projectTeams        ProjectTeam[]
  issues              Issue[]
  issueTemplates      IssueTemplate[]
  activityEvents      ActivityEvent[]
  importSourceRows    ImportSourceRow[]

  @@unique([workspaceId, id])
  @@index([workspaceId, archivedAt, updatedAt, id])
  @@index([workspaceId, status, updatedAt, id])
  @@index([workspaceId, leadMembershipId, updatedAt, id])
  @@index([workspaceId, targetDate, id])
  @@index([workspaceId, deletedAt, createdAt, id])
  @@map("projects")
}

model ProjectRoleTeam {
  workspaceId String      @map("workspace_id") @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  role        ProjectRole
  teamId      String      @map("team_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project   Project   @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Restrict)
  team      Team      @relation(fields: [workspaceId, teamId], references: [workspaceId, id], onDelete: Restrict)

  @@id([projectId, role])
  @@unique([workspaceId, projectId, role])
  @@unique([workspaceId, projectId, role, teamId])
  @@index([workspaceId, teamId, projectId, role])
  @@map("project_role_teams")
}

model ProjectTeam {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @map("workspace_id") @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  teamId        String    @map("team_id") @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project        Project         @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Restrict)
  team           Team            @relation(fields: [workspaceId, teamId], references: [workspaceId, id], onDelete: Restrict)
  teamWorks      TeamWork[]
  issueTemplates IssueTemplate[] @relation("IssueTemplateInitialProjectTeam")

  @@unique([workspaceId, id])
  @@unique([workspaceId, projectId, id])
  @@unique([workspaceId, teamId, id])
  @@unique([projectId, teamId])
  @@index([workspaceId, projectId, isActive, teamId])
  @@index([workspaceId, teamId, isActive, projectId])
  @@map("project_teams")
}

model IssueTemplate {
  id                   String        @id @default(uuid()) @db.Uuid
  workspaceId          String        @map("workspace_id") @db.Uuid
  name                 String        @db.VarChar(100)
  normalizedName       String        @map("normalized_name") @db.VarChar(100)
  descriptionMarkdown  String        @map("description_markdown") @db.Text
  priority             IssuePriority @default(NONE)
  projectId            String?       @map("project_id") @db.Uuid
  initialRole          ProjectRole?  @map("initial_role")
  initialProjectTeamId String?       @map("initial_project_team_id") @db.Uuid
  archivedAt           DateTime?     @map("archived_at") @db.Timestamptz(3)
  version              Int           @default(1)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project            Project?             @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Restrict)
  initialProjectTeam ProjectTeam?         @relation("IssueTemplateInitialProjectTeam", fields: [workspaceId, projectId, initialProjectTeamId], references: [workspaceId, projectId, id], onDelete: Restrict)
  labels             IssueTemplateLabel[]

  @@unique([workspaceId, id])
  @@index([workspaceId, archivedAt, updatedAt, id])
  @@index([workspaceId, projectId])
  @@map("issue_templates")
}

model IssueTemplateLabel {
  workspaceId     String @map("workspace_id") @db.Uuid
  issueTemplateId String @map("issue_template_id") @db.Uuid
  labelId         String @map("label_id") @db.Uuid

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issueTemplate IssueTemplate @relation(fields: [workspaceId, issueTemplateId], references: [workspaceId, id], onDelete: Cascade)
  label         Label         @relation(fields: [workspaceId, labelId], references: [workspaceId, id], onDelete: Restrict)

  @@id([issueTemplateId, labelId])
  @@index([workspaceId, labelId, issueTemplateId], map: "issue_template_labels_workspace_label_template_idx")
  @@map("issue_template_labels")
}

model Issue {
  id                    String        @id @default(uuid()) @db.Uuid
  workspaceId           String        @map("workspace_id") @db.Uuid
  identifier            String        @db.VarChar(32)
  sequenceNumber        Int           @map("sequence_number")
  title                 String        @db.VarChar(500)
  descriptionMarkdown   String?       @map("description_markdown") @db.Text
  status                IssueStatus   @default(UNSORTED)
  priority              IssuePriority @default(NONE)
  projectId             String        @map("project_id") @db.Uuid
  createdByMembershipId String        @map("created_by_membership_id") @db.Uuid
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz(3)
  purgeAt               DateTime?     @map("purge_at") @db.Timestamptz(3)
  deletedByMembershipId String?       @map("deleted_by_membership_id") @db.Uuid
  version               Int           @default(1)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace           Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project             Project               @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Restrict)
  createdByMembership WorkspaceMembership   @relation("IssueCreatorMembership", fields: [workspaceId, createdByMembershipId], references: [workspaceId, id], onDelete: Restrict)
  deletedByMembership WorkspaceMembership?  @relation("IssueDeletedByMembership", fields: [workspaceId, deletedByMembershipId], references: [workspaceId, id], onDelete: Restrict)
  teamWorks           TeamWork[]
  labels              IssueLabel[]
  subscriptions       IssueSubscription[]
  activityEvents      ActivityEvent[]
  handoffs            ApiHandoff[]
  notifications       Notification[]
  comments            Comment[]
  mentions            Mention[]
  fileAttachments     IssueFileAttachment[]
  importSourceRows    ImportSourceRow[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, identifier])
  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, status, updatedAt, id])
  @@index([workspaceId, projectId, updatedAt, id])
  @@index([workspaceId, deletedAt, createdAt, id])
  @@index([workspaceId, deletedAt, updatedAt, id])
  @@map("issues")
}

model TeamWork {
  id                    String      @id @default(uuid()) @db.Uuid
  workspaceId           String      @map("workspace_id") @db.Uuid
  issueId               String      @map("issue_id") @db.Uuid
  identifier            String      @db.VarChar(32)
  sequenceNumber        Int         @map("sequence_number")
  projectRole           ProjectRole @default(BACKEND) @map("project_role")
  projectTeamId         String?     @map("project_team_id") @db.Uuid
  teamId                String      @map("team_id") @db.Uuid
  workflowStateId       String      @map("workflow_state_id") @db.Uuid
  assigneeMembershipId  String?     @map("assignee_membership_id") @db.Uuid
  workNoteMarkdown      String?     @map("work_note_markdown") @db.VarChar(10000)
  createdByMembershipId String      @map("created_by_membership_id") @db.Uuid
  deletedAt             DateTime?   @map("deleted_at") @db.Timestamptz(3)
  version               Int         @default(1)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issue               Issue               @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  team                Team                @relation(fields: [workspaceId, teamId], references: [workspaceId, id], onDelete: Restrict)
  projectTeam         ProjectTeam?        @relation(fields: [workspaceId, teamId, projectTeamId], references: [workspaceId, teamId, id], onDelete: Restrict)
  workflowState       WorkflowState       @relation(fields: [workspaceId, teamId, workflowStateId], references: [workspaceId, teamId, id], onDelete: Restrict)
  assigneeTeamMember  TeamMember?         @relation("TeamWorkAssigneeTeamMember", fields: [workspaceId, teamId, assigneeMembershipId], references: [workspaceId, teamId, membershipId], onDelete: Restrict)
  createdByMembership WorkspaceMembership @relation("TeamWorkCreatorMembership", fields: [workspaceId, createdByMembershipId], references: [workspaceId, id], onDelete: Restrict)
  sourceHandoffs      ApiHandoff[]        @relation("ApiHandoffSourceTeamWork")
  handoffTargets      ApiHandoffTarget[]
  comments            Comment[]
  mentions            Mention[]
  activityEvents      ActivityEvent[]
  notifications       Notification[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, issueId, id])
  @@unique([teamId, sequenceNumber])
  @@index([workspaceId, issueId, deletedAt, updatedAt, id])
  @@index([workspaceId, teamId, deletedAt, updatedAt, id])
  @@index([workspaceId, assigneeMembershipId, deletedAt, updatedAt, id])
  @@index([workspaceId, workflowStateId, id])
  @@index([workspaceId, projectRole, id])
  @@index([workspaceId, projectTeamId, deletedAt, updatedAt, id])
  @@map("team_works")
}

model ApiHandoff {
  id                 String      @id @default(uuid()) @db.Uuid
  workspaceId        String      @map("workspace_id") @db.Uuid
  issueId            String      @map("issue_id") @db.Uuid
  sourceTeamWorkId   String      @map("source_team_work_id") @db.Uuid
  kind               HandoffKind
  sequenceNumber     Int         @map("sequence_number")
  bodyMarkdown       String      @map("body_markdown") @db.Text
  authorMembershipId String      @map("author_membership_id") @db.Uuid
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issue            Issue                 @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  sourceTeamWork   TeamWork              @relation("ApiHandoffSourceTeamWork", fields: [workspaceId, issueId, sourceTeamWorkId], references: [workspaceId, issueId, id], onDelete: Cascade)
  authorMembership WorkspaceMembership   @relation("ApiHandoffAuthorMembership", fields: [workspaceId, authorMembershipId], references: [workspaceId, id], onDelete: Restrict)
  targets          ApiHandoffTarget[]
  notifications    Notification[]
  fileAttachments  IssueFileAttachment[]
  mentions         Mention[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, issueId, id])
  @@unique([sourceTeamWorkId, sequenceNumber])
  @@index([workspaceId, issueId, createdAt, id])
  @@map("api_handoffs")
}

model ApiHandoffTarget {
  workspaceId String @map("workspace_id") @db.Uuid
  handoffId   String @map("handoff_id") @db.Uuid
  teamWorkId  String @map("team_work_id") @db.Uuid

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  handoff   ApiHandoff @relation(fields: [workspaceId, handoffId], references: [workspaceId, id], onDelete: Cascade)
  teamWork  TeamWork   @relation(fields: [workspaceId, teamWorkId], references: [workspaceId, id], onDelete: Cascade)

  @@id([handoffId, teamWorkId])
  @@index([workspaceId, teamWorkId, handoffId])
  @@map("api_handoff_targets")
}

model IssueLabel {
  workspaceId String @map("workspace_id") @db.Uuid
  issueId     String @map("issue_id") @db.Uuid
  labelId     String @map("label_id") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issue     Issue     @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  label     Label     @relation(fields: [workspaceId, labelId], references: [workspaceId, id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@index([workspaceId, labelId, issueId])
  @@map("issue_labels")
}

model IssueSubscription {
  workspaceId  String   @map("workspace_id") @db.Uuid
  issueId      String   @map("issue_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issue      Issue               @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  membership WorkspaceMembership @relation(fields: [workspaceId, membershipId], references: [workspaceId, id], onDelete: Restrict)

  @@id([issueId, membershipId])
  @@index([workspaceId, membershipId, issueId])
  @@map("issue_subscriptions")
}

model ActivityEvent {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @map("workspace_id") @db.Uuid
  issueId           String?  @map("issue_id") @db.Uuid
  teamWorkId        String?  @map("team_work_id") @db.Uuid
  projectId         String?  @map("project_id") @db.Uuid
  actorMembershipId String?  @map("actor_membership_id") @db.Uuid
  eventType         String   @map("event_type") @db.VarChar(100)
  fieldName         String?  @map("field_name") @db.VarChar(100)
  beforeData        Json?    @map("before_data") @db.JsonB
  afterData         Json?    @map("after_data") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  issue           Issue?               @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  teamWork        TeamWork?            @relation(fields: [workspaceId, teamWorkId], references: [workspaceId, id], onDelete: Cascade)
  project         Project?             @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  actorMembership WorkspaceMembership? @relation("ActivityActorMembership", fields: [workspaceId, actorMembershipId], references: [workspaceId, id], onDelete: Restrict)

  @@index([workspaceId, issueId, createdAt, id])
  @@index([workspaceId, teamWorkId, createdAt, id])
  @@index([workspaceId, projectId, createdAt, id])
  @@map("activity_events")
}

model Notification {
  id                    String           @id @default(uuid()) @db.Uuid
  workspaceId           String           @map("workspace_id") @db.Uuid
  eventId               String           @map("event_id") @db.Uuid
  recipientMembershipId String           @map("recipient_membership_id") @db.Uuid
  type                  NotificationType
  actorMembershipId     String?          @map("actor_membership_id") @db.Uuid
  issueId               String           @map("issue_id") @db.Uuid
  teamWorkId            String?          @map("team_work_id") @db.Uuid
  commentId             String?          @map("comment_id") @db.Uuid
  handoffId             String?          @map("handoff_id") @db.Uuid
  readAt                DateTime?        @map("read_at") @db.Timestamptz(3)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  recipientMembership WorkspaceMembership  @relation("NotificationRecipientMembership", fields: [workspaceId, recipientMembershipId], references: [workspaceId, id], onDelete: Restrict)
  actorMembership     WorkspaceMembership? @relation("NotificationActorMembership", fields: [workspaceId, actorMembershipId], references: [workspaceId, id], onDelete: Restrict)
  issue               Issue                @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Cascade)
  teamWork            TeamWork?            @relation(fields: [workspaceId, teamWorkId], references: [workspaceId, id], onDelete: Cascade)
  comment             Comment?             @relation(fields: [workspaceId, issueId, commentId], references: [workspaceId, issueId, id], onDelete: Cascade, map: "notifications_workspace_issue_comment_fkey")
  handoff             ApiHandoff?          @relation(fields: [workspaceId, handoffId], references: [workspaceId, id], onDelete: Cascade)
  webPushDeliveries   WebPushDelivery[]

  @@unique([workspaceId, id])
  @@unique([eventId, recipientMembershipId])
  @@index([workspaceId, recipientMembershipId, readAt, createdAt, id])
  @@index([workspaceId, issueId, createdAt, id])
  @@index([workspaceId, teamWorkId, createdAt, id])
  @@map("notifications")
}

model WebPushSubscription {
  id              String                    @id @default(uuid()) @db.Uuid
  workspaceId     String                    @map("workspace_id") @db.Uuid
  membershipId    String                    @map("membership_id") @db.Uuid
  sessionId       String?                   @map("session_id") @db.Uuid
  browser         WebPushBrowser
  endpointHash    String                    @map("endpoint_hash") @db.Char(64)
  endpoint        String?                   @db.Text
  p256dh          String?                   @db.Text
  auth            String?                   @db.Text
  expirationTime  DateTime?                 @map("expiration_time") @db.Timestamptz(3)
  status          WebPushSubscriptionStatus @default(ACTIVE)
  lastSucceededAt DateTime?                 @map("last_succeeded_at") @db.Timestamptz(3)
  lastFailedAt    DateTime?                 @map("last_failed_at") @db.Timestamptz(3)
  lastErrorCode   String?                   @map("last_error_code") @db.VarChar(100)
  disabledAt      DateTime?                 @map("disabled_at") @db.Timestamptz(3)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  membership WorkspaceMembership @relation(fields: [workspaceId, membershipId], references: [workspaceId, id], onDelete: Restrict)
  session    Session?            @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  deliveries WebPushDelivery[]

  @@unique([workspaceId, id])
  @@unique([membershipId, endpointHash])
  @@index([workspaceId, membershipId, status, createdAt, id], map: "web_push_subscriptions_workspace_id_membership_id_status_create")
  @@index([sessionId, status])
  @@map("web_push_subscriptions")
}

model WebPushDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  notificationId String?               @map("notification_id") @db.Uuid
  outboxEventId  String?               @map("outbox_event_id") @db.Uuid
  subscriptionId String                @map("subscription_id") @db.Uuid
  status         WebPushDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0) @map("attempt_count")
  sentAt         DateTime?             @map("sent_at") @db.Timestamptz(3)
  failedAt       DateTime?             @map("failed_at") @db.Timestamptz(3)
  lastErrorCode  String?               @map("last_error_code") @db.VarChar(100)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  notification Notification?       @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  outboxEvent  OutboxEvent?        @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)
  subscription WebPushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@unique([notificationId, subscriptionId])
  @@unique([outboxEventId, subscriptionId])
  @@index([subscriptionId, status, createdAt, id])
  @@map("web_push_deliveries")
}
