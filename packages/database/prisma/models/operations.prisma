model OutboxEvent {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String?   @map("workspace_id") @db.Uuid
  eventType         String    @map("event_type") @db.VarChar(100)
  aggregateType     String    @map("aggregate_type") @db.VarChar(100)
  aggregateId       String    @map("aggregate_id") @db.Uuid
  actorMembershipId String?   @map("actor_membership_id") @db.Uuid
  payload           Json      @default("{}") @db.JsonB
  availableAt       DateTime  @default(now()) @map("available_at") @db.Timestamptz(3)
  attemptCount      Int       @default(0) @map("attempt_count")
  nextAttemptAt     DateTime? @map("next_attempt_at") @db.Timestamptz(3)
  lastErrorCode     String?   @map("last_error_code") @db.VarChar(100)
  lockedAt          DateTime? @map("locked_at") @db.Timestamptz(3)
  lockedBy          String?   @map("locked_by") @db.VarChar(100)
  processedAt       DateTime? @map("processed_at") @db.Timestamptz(3)
  canceledAt        DateTime? @map("canceled_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace         Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  actorMembership   WorkspaceMembership? @relation("OutboxActorMembership", fields: [workspaceId, actorMembershipId], references: [workspaceId, id], onDelete: Restrict)
  emailDelivery     EmailDelivery?
  webPushDeliveries WebPushDelivery[]

  @@unique([workspaceId, id])
  @@map("outbox_events")
}

enum EmailTemplateType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  WORKSPACE_INVITATION
}

model EmailDelivery {
  id                String            @id @default(uuid()) @db.Uuid
  outboxEventId     String            @unique @map("outbox_event_id") @db.Uuid
  templateType      EmailTemplateType @map("template_type")
  recipientEmail    String            @map("recipient_email") @db.VarChar(254)
  providerMessageId String?           @map("provider_message_id") @db.VarChar(255)
  sentAt            DateTime?         @map("sent_at") @db.Timestamptz(3)
  failedAt          DateTime?         @map("failed_at") @db.Timestamptz(3)
  lastErrorCode     String?           @map("last_error_code") @db.VarChar(100)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  outboxEvent OutboxEvent @relation(fields: [outboxEventId], references: [id], onDelete: Restrict)

  @@map("email_deliveries")
}

enum ExportType {
  ISSUES
  PROJECTS
}

model ExportAudit {
  id                      String     @id @default(uuid()) @db.Uuid
  workspaceId             String     @map("workspace_id") @db.Uuid
  requestedByMembershipId String     @map("requested_by_membership_id") @db.Uuid
  type                    ExportType
  itemCount               Int?       @map("item_count")
  requestedAt             DateTime   @default(now()) @map("requested_at") @db.Timestamptz(3)
  completedAt             DateTime?  @map("completed_at") @db.Timestamptz(3)
  failedAt                DateTime?  @map("failed_at") @db.Timestamptz(3)
  downloadedAt            DateTime?  @map("downloaded_at") @db.Timestamptz(3)
  lastErrorCode           String?    @map("last_error_code") @db.VarChar(100)

  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  requestedByMembership WorkspaceMembership @relation("ExportRequesterMembership", fields: [workspaceId, requestedByMembershipId], references: [workspaceId, id], onDelete: Restrict)

  @@index([workspaceId, requestedAt, id])
  @@index([workspaceId, requestedByMembershipId, requestedAt, id], map: "export_audits_requester_requested_at_id_idx")
  @@map("export_audits")
}

enum ImportRunStatus {
  PREVIEWED
  VALIDATION_FAILED
  VALIDATED
  PROCESSING
  SUCCEEDED
  FAILED
}

model ImportRun {
  id                         String          @id @default(uuid()) @db.Uuid
  workspaceId                String          @map("workspace_id") @db.Uuid
  requestedByMembershipId    String          @map("requested_by_membership_id") @db.Uuid
  executionId                String          @map("execution_id") @db.Uuid
  sourceFingerprint          String          @map("source_fingerprint") @db.Char(64)
  status                     ImportRunStatus
  inputRowCount              Int             @default(0) @map("input_row_count")
  projectCreatedCount        Int             @default(0) @map("project_created_count")
  issueCreatedCount          Int             @default(0) @map("issue_created_count")
  connectionCreatedCount     Int             @default(0) @map("connection_created_count")
  excludedRowCount           Int             @default(0) @map("excluded_row_count")
  errorCount                 Int             @default(0) @map("error_count")
  lastErrorCode              String?         @map("last_error_code") @db.VarChar(100)
  errorDetails               Json?           @map("error_details") @db.JsonB
  validatedTargetFingerprint String?         @map("validated_target_fingerprint") @db.Char(64)
  validationSignature        String?         @map("validation_signature") @db.Char(64)
  startedAt                  DateTime?       @map("started_at") @db.Timestamptz(3)
  completedAt                DateTime?       @map("completed_at") @db.Timestamptz(3)
  failedAt                   DateTime?       @map("failed_at") @db.Timestamptz(3)
  createdAt                  DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  requestedByMembership WorkspaceMembership @relation("ImportRequesterMembership", fields: [workspaceId, requestedByMembershipId], references: [workspaceId, id], onDelete: Restrict)
  sourceRows            ImportSourceRow[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, executionId])
  @@index([workspaceId, sourceFingerprint, status, createdAt, id], map: "import_runs_workspace_id_source_fingerprint_status_created_at_i")
  @@index([workspaceId, createdAt, id])
  @@map("import_runs")
}

model ImportSourceRow {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  importRunId     String   @map("import_run_id") @db.Uuid
  sourceKeyHash   String   @map("source_key_hash") @db.Char(64)
  sourceReference String   @map("source_reference") @db.VarChar(255)
  projectId       String   @map("project_id") @db.Uuid
  projectCreated  Boolean  @default(false) @map("project_created")
  issueId         String   @map("issue_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  importRun ImportRun @relation(fields: [workspaceId, importRunId], references: [workspaceId, id], onDelete: Restrict)
  project   Project   @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Restrict)
  issue     Issue     @relation(fields: [workspaceId, issueId], references: [workspaceId, id], onDelete: Restrict)

  @@unique([workspaceId, id])
  @@unique([workspaceId, sourceKeyHash])
  @@unique([workspaceId, issueId])
  @@index([workspaceId, importRunId, createdAt, id])
  @@index([workspaceId, projectId, createdAt, id])
  @@map("import_source_rows")
}
