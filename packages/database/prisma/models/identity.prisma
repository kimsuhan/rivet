enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  WORKSPACE_INVITATION
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @db.VarChar(254)
  normalizedEmail String    @unique @map("normalized_email") @db.VarChar(254)
  passwordHash    String    @map("password_hash") @db.Text
  displayName     String    @map("display_name") @db.VarChar(50)
  avatarFileId    String?   @unique @map("avatar_file_id") @db.Uuid
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  avatarFile          File?                 @relation("UserAvatarFile", fields: [avatarFileId], references: [id], onDelete: Restrict)
  uploadedFiles       File[]                @relation("FileUploader")
  sessions            Session[]
  oneTimeTokens       OneTimeToken[]
  createdWorkspaces   Workspace[]           @relation("WorkspaceCreator")
  membership          WorkspaceMembership?
  acceptedInvitations WorkspaceInvitation[] @relation("InvitationAcceptor")

  @@map("users")
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         Bytes     @unique @map("token_hash") @db.ByteA
  lastSeenAt        DateTime  @map("last_seen_at") @db.Timestamptz(3)
  idleExpiresAt     DateTime  @map("idle_expires_at") @db.Timestamptz(3)
  absoluteExpiresAt DateTime  @map("absolute_expires_at") @db.Timestamptz(3)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  webPushSubscriptions WebPushSubscription[]

  @@index([userId])
  @@map("sessions")
}

model OneTimeToken {
  id           String       @id @default(uuid()) @db.Uuid
  purpose      TokenPurpose
  userId       String?      @map("user_id") @db.Uuid
  invitationId String?      @map("invitation_id") @db.Uuid
  tokenHash    Bytes        @unique @map("token_hash") @db.ByteA
  expiresAt    DateTime     @map("expires_at") @db.Timestamptz(3)
  usedAt       DateTime?    @map("used_at") @db.Timestamptz(3)
  revokedAt    DateTime?    @map("revoked_at") @db.Timestamptz(3)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  user       User?                @relation(fields: [userId], references: [id], onDelete: Restrict)
  invitation WorkspaceInvitation? @relation(fields: [invitationId], references: [id], onDelete: Restrict)

  @@index([userId, purpose])
  @@index([invitationId, purpose])
  @@map("one_time_tokens")
}

model AuthRateLimitBucket {
  id              String    @id @default(uuid()) @db.Uuid
  scope           String    @db.VarChar(100)
  keyHash         Bytes     @map("key_hash") @db.ByteA
  windowStartedAt DateTime  @map("window_started_at") @db.Timestamptz(3)
  attemptCount    Int       @default(0) @map("attempt_count")
  blockedUntil    DateTime? @map("blocked_until") @db.Timestamptz(3)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([scope, keyHash, windowStartedAt])
  @@index([expiresAt, id])
  @@map("auth_rate_limit_buckets")
}
