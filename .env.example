# 로컬 개발에서는 이 파일을 .env.local로 복사한 뒤 값을 채웁니다.
# 실제 비밀 값은 이 예시 파일이나 Git 추적 파일에 저장하지 않습니다.

# 로컬은 development, 운영 서버는 production을 사용합니다. test는 테스트 명령이 설정합니다.
NODE_ENV=development
# 같은 배포의 Web·API·Worker가 공유할 식별자입니다. 운영은 Git SHA나 릴리스 태그를 사용합니다.
RELEASE_ID=local
# 브라우저가 접속하는 공개 origin입니다. 경로나 끝 슬래시 없이, 운영에서는 HTTPS를 사용합니다.
WEB_ORIGIN=http://127.0.0.1:3000
# Web 서버가 내부에서 API에 접근할 origin입니다. /api 경로는 붙이지 않습니다.
API_INTERNAL_ORIGIN=http://127.0.0.1:4000

# 실제 PostgreSQL 사용자·비밀번호·호스트·DB 이름으로 바꿉니다. 비밀번호의 특수문자는 URL 인코딩합니다.
DATABASE_URL=postgresql://rivet:change-me@localhost:5432/rivet?schema=public
# 아래 세 값은 각각 `openssl rand -hex 32`로 따로 생성하며 서로 같은 값을 사용하지 않습니다.
ONE_TIME_TOKEN_HMAC_KEY=
CSRF_HMAC_KEY=
RATE_LIMIT_HMAC_KEY=

# Web Push용 VAPID 키 쌍은 저장소 밖에서 한 번 생성합니다.
# 로컬 생성 명령: pnpm --filter @rivet/worker exec web-push generate-vapid-keys
# PUBLIC_KEY는 API와 Worker에 같은 값을 주입합니다. 운영의 PRIVATE_KEY와 SUBJECT는 Worker 전용
# 환경 변수로 주입하고, 특히 PRIVATE_KEY는 Secret으로 관리해 공용 환경 파일·DB·로그·Git에 저장하지 않습니다.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# mailto:ops@example.com 또는 경로·끝 슬래시 없는 HTTPS origin을 사용합니다.
WEB_PUSH_VAPID_SUBJECT=

# Resend 대시보드에서 발급한 개발/운영 환경별 API 키입니다. Worker 실행에 필수입니다.
RESEND_API_KEY=
# Resend에서 검증된 도메인의 발신 이메일 주소만 넣습니다. 표시 이름 형식은 사용하지 않습니다.
# onboarding@resend.dev는 Resend 계정 주소 한 곳에만 보낼 수 있으므로 두 주소로 초대를 시험할 때는
# 별도 도메인을 검증하고 그 도메인의 발신 주소를 사용합니다.
RESEND_FROM=
# development/test에서만 적용하는 쉼표 구분 수신 허용 목록입니다. 실제 수신 가능한 테스트 주소 2개를 넣습니다.
# 운영 환경에서는 빈 문자열로 주입하지 말고 이 변수 자체를 생략합니다.
RESEND_ALLOWED_RECIPIENTS=
# PostHog 프로젝트 API 키(phc_...)입니다. development에서는 비워도 되지만 production에서는 필수입니다.
POSTHOG_API_KEY=
# Slack Incoming Webhook의 https://hooks.slack.com/services/... URL입니다. production에서는 필수입니다.
SLACK_ALERT_WEBHOOK_URL=

# RIVET_EXTERNAL_SMOKE_TARGET/CONFIRM은 스모크 실행 때만 셸에 주입하고 이 파일에 저장하지 않습니다.

# DATABASE_POOL_MAX는 API(기본 10)와 Worker(기본 5)가 다르므로 공통 파일에 넣지 않습니다.
# 조정이 필요할 때만 각 프로세스 환경에 1~100 범위로 따로 설정합니다.
# 아래 timeout은 밀리초이며 특별한 운영 근거가 없으면 기본값을 유지합니다.
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
# API와 Worker가 함께 사용하는 영구 저장소의 쓰기 가능한 절대 경로입니다.
FILE_STORAGE_ROOT=/absolute/path/to/rivet-files
# 로컬 내부 포트입니다. 변경하면 프록시와 API_INTERNAL_ORIGIN도 함께 맞춥니다.
API_PORT=4000
WEB_PORT=3000
